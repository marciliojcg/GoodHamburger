@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <nav class="navbar navbar-dark bg-dark flex-column">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">
                    🍔 Good Hamburger
                </a>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/pedidos">
                            📋 Lista de Pedidos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/pedido/novo">
                            ➕ Novo Pedido
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
    </div>

    <main>
        <div class="top-row px-4 bg-white">
            <span class="ms-auto">Sistema de Pedidos</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    .sidebar {
        background-image: linear-gradient(180deg, rgb(5, 39, 103) 0%, #3a0647 70%);
        min-height: 100vh;
        width: 250px;
    }

    .content {
        padding-top: 1.1rem;
    }

    .navbar-brand {
        font-size: 1.5rem;
        padding: 1rem;
    }

    .nav-link {
        padding: 0.75rem 1rem;
        transition: background-color 0.3s;
    }

    .nav-link:hover {
        background-color: rgba(255,255,255,0.1);
    }
</style>