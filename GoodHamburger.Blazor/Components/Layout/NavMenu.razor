@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <nav class="navbar navbar-dark bg-dark flex-column">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">
                    🍔 Good Hamburger
                </a>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/pedidos">
                            📋 Lista de Pedidos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/pedido/novo">
                            ➕ Novo Pedido
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
    </div>

