@page "/pedido/novo"
@rendermode InteractiveServer
@using GoodHamburger.Blazor.Models
@using GoodHamburger.Blazor.Services
@using GoodHamburger.Blazor.Services.Interfaces
@inject IPedidoService PedidoService
@inject ICardapioService CardapioService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<h2 class="mb-4">🍔 Novo Pedido</h2>

@if (carregando)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Carregando...</span>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Dados do Pedido</h5>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h6 class="fw-bold">🍔 Sanduíche</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label">Tipo de Sanduíche</label>
                                <select class="form-select" @bind="sanduicheSelecionado" >
                                    <option value="">Selecione um sanduíche...</option>
                                    @foreach (var sanduiche in sanduiches)
                                    {
                                        <option value="@sanduiche.Nome">@sanduiche.Nome - R$ @sanduiche.Preco.ToString("F2")</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Quantidade</label>
                                <input type="number" class="form-control" @bind="quantidadeSanduiche"  min="1" max="10" />
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6 class="fw-bold">🍟 Acompanhamentos</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Acompanhamento 1</label>
                                <select class="form-select" @bind="acompanhamento1Selecionado" >
                                    <option value="">Selecione um acompanhamento...</option>
                                    @foreach (var item in acompanhamentos)
                                    {
                                        <option value="@item.Nome">@item.Nome - R$ @item.Preco.ToString("F2")</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Quantidade</label>
                                <input type="number" class="form-control" @bind="quantidadeAcompanhamento1"  min="0" max="10" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <label class="form-label">Acompanhamento 2</label>
                                <select class="form-select" @bind="acompanhamento2Selecionado">
                                    <option value="">Selecione um acompanhamento...</option>
                                    @foreach (var item in acompanhamentos)
                                    {
                                        <option value="@item.Nome">@item.Nome - R$ @item.Preco.ToString("F2")</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Quantidade</label>
                                <input type="number" class="form-control" @bind="quantidadeAcompanhamento2" min="0" max="10" />
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <strong>💡 Regras de Desconto:</strong>
                        <ul class="mb-0 mt-2">
                            <li>Sanduíche + Batata + Refrigerante → 20% de desconto</li>
                            <li>Sanduíche + Refrigerante → 15% de desconto</li>
                            <li>Sanduíche + Batata → 10% de desconto</li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <button class="btn btn-secondary" @onclick="Cancelar" type="button">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                        <button class="btn btn-success" @onclick="SalvarPedido" disabled="@(!PedidoValido())" type="button">
                            <i class="bi bi-check-circle"></i> Salvar Pedido
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">📊 Resumo do Pedido</h5>
                </div>
                <div class="card-body">
                    <div id="resumo-pedido">
                        @if (itensPedido.Any())
                        {
                            @foreach (var item in itensPedido)
                            {
                                <div class="d-flex justify-content-between mb-2">
                                    <span>@item.Nome </span>
                                </div>
                            }
                            <hr />
                            <div class="d-flex justify-content-between">
                                <strong>Subtotal:</strong>
                                <span>R$ @subtotal.ToString("F2")</span>
                            </div>
                            <div class="d-flex justify-content-between text-success">
                                <strong>Desconto:</strong>
                                <span>-R$ @desconto.ToString("F2")</span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between fw-bold">
                                <strong>Total:</strong>
                                <span class="text-primary">R$ @total.ToString("F2")</span>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center mb-0">
                                Selecione os itens do pedido
                            </p>    
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
